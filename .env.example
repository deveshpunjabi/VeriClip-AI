# Environment variables for VeriClip AI
# Copy this file to .env and fill in your actual values

# Application
APP_NAME=VeriClip AI
APP_VERSION=0.1.0
DEBUG=false

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=asia-south1

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_X509_CERT_URL=

# Gemini / Vertex AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_FINGERPRINT=gemini-2.0-flash
GEMINI_MODEL_VERIFY=gemini-2.5-pro

# Custom Search (for scanner agent)
CUSTOM_SEARCH_API_KEY=your-custom-search-api-key
CUSTOM_SEARCH_ENGINE_ID=your-custom-search-engine-id

# Cloud Storage
MEDIA_BUCKET=vericlip-media-official
THREAT_EVIDENCE_BUCKET=vericlip-threats-evidence
